## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## See https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (DotSettings)
*.DotSettings.user

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww]in32/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
Log/
logs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you use Visual Studio Code
.vscode/

# Visual Studio 2017 auto generated files
Generated\ Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build log files
*.log

# External libraries (depend on the project)
/packages/
# Libs
/lib/

# Miscellaneous
/bin/
/obj/
*.sln.cache
*.vssscc
*.vspscc
*.bak
*.cache
*.docstates
*.user
*.userosscache
*.suo

# Local history
.history/
